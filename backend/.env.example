# ============================================
# Telegram Mini App 后端配置
# 复制此文件为 .env 并填入真实值
# ============================================

# 服务器配置
PORT=3000
NODE_ENV=development

# Telegram Bot 配置（从 @BotFather 获取）
BOT_TOKEN=your_bot_token_here
# Webhook URL（部署后的公网地址）
WEBHOOK_URL=https://your-backend-domain.com/webhook

# 数据库（PostgreSQL）
DATABASE_URL=postgresql://user:password@localhost:5432/telegram_miniapp?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# TON 支付配置
TON_MERCHANT_ADDRESS=your_ton_wallet_address
TON_API_KEY=your_toncenter_api_key

# USDT 稳定币配置
# Mainnet: EQCxE6mUtQJKFnGfaROTKOt1lZbDiiX1kCixRv7Nw2Id_sDs
# Testnet: kQD0GKBM8ZbryVk2aESmzfU6b9b_8era_IkvBSELujFZPsyy
USDT_MASTER_ADDRESS=kQD0GKBM8ZbryVk2aESmzfU6b9b_8era_IkvBSELujFZPsyy

# TON Pay SDK（可选，如果使用 TON Pay 托管方案）
# 在 https://pay.ton.org 商户后台获取
TON_PAY_API_KEY=your_ton_pay_api_key

# CORS（前端地址）
FRONTEND_URL=https://your-miniapp-domain.com

# JWT Secret（用于内部 token 生成）
JWT_SECRET=your_random_secret_here_at_least_32_chars
